{
  "kind": "collectionType",
  "collectionName": "photo_categories",
  "info": {
    "singularName": "photo-category",
    "pluralName": "photo-categories",
    "displayName": "Photo Category",
    "description": "图片分类"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "photos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::photo.photo",
      "mappedBy": "category"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "sort": {
      "type": "integer",
      "default": 0
    }
  }
}