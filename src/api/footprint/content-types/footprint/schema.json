{
  "kind": "collectionType",
  "collectionName": "footprints",
  "info": {
    "singularName": "footprint",
    "pluralName": "footprints",
    "displayName": "Footprint",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "latitude": {
      "type": "decimal",
      "required": true
    },
    "longitude": {
      "type": "decimal",
      "required": true
    },
    "city": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "visitedAt": {
      "type": "date"
    },
    "description": {
      "type": "text"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "photos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::photo.photo",
      "mappedBy": "footprint"
    }
  }
}
